      "cooked": "<aside class=\"onebox whitelistedgeneric\">\n  <header class=\"source\">\n      <img src=\"https://images-na.ssl-images-amazon.com/images/G/01/imdb/images/safari-favicon-517611381._CB514892156_.svg\" class=\"site-icon\" width=\"800\" height=\"800\">\n      <a href=\"http://m.imdb.com/title/tt0056241/\" target=\"_blank\" rel=\"nofollow noopener\">IMDb</a>\n  </header>\n  <article class=\"onebox-body\">\n    <div class=\"aspect-image\" style=\"--aspect-ratio:420/800;\"><img src=\"https://images-na.ssl-images-amazon.com/images/M/MV5BMTQzODc4MTE1MF5BMl5BanBnXkFtZTcwMjYyODI1NA@@._V1_UY1200_CR85,0,630,1200_AL_.jpg\" class=\"thumbnail\"></div>\n\n<h3><a href=\"http://m.imdb.com/title/tt0056241/\" target=\"_blank\" rel=\"nofollow noopener\">The Miracle Worker (1962)</a></h3>\n\n<p>Directed by Arthur Penn.  With Anne Bancroft, Patty Duke, Victor Jory, Inga Swenson. The story of Anne Sullivan's struggle to teach the blind and deaf Helen Keller how to communicate.</p>\n\n\n  </article>\n  <div class=\"onebox-metadata\">\n    \n    \n  </div>\n  <div style=\"clear: both\"></div>\n</aside>\n",
