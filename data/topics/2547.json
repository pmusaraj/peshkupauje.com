      "cooked": "<p><div class=\"lightbox-wrapper\"><a class=\"lightbox\" href=\"https://peshkupauje.com/uploads/default/original/2X/b/be60830f542e0ea58b6528d085063320dba89240.jpg\" data-download-href=\"https://peshkupauje.com/uploads/default/be60830f542e0ea58b6528d085063320dba89240\" title=\"barco%2Beuropa.jpg\"><img src=\"https://peshkupauje.com/uploads/default/original/2X/b/be60830f542e0ea58b6528d085063320dba89240.jpg\" width=\"800\" height=\"479\" data-small-upload=\"https://peshkupauje.com/uploads/default/optimized/2X/b/be60830f542e0ea58b6528d085063320dba89240_2_10x10.png\"><div class=\"meta\">\n<svg class=\"fa d-icon d-icon-far-image svg-icon\" aria-hidden=\"true\"><use xlink:href=\"#far-image\"></use></svg><span class=\"filename\">barco%2Beuropa.jpg</span><span class=\"informations\">1555×933 261 KB</span><svg class=\"fa d-icon d-icon-discourse-expand svg-icon\" aria-hidden=\"true\"><use xlink:href=\"#discourse-expand\"></use></svg>\n</div></a></div></p>",
