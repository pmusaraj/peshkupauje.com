    {
      "id": 106707,
      "post_number": 6,
      "username": "Alba2265",
      "name": "",
      "avatar_template": "/letter_avatar_proxy/v4/letter/a/85e7bf/{size}.png",
      "created_at": "2019-12-27T14:32:35.020Z",
      "cooked": "<p><strong>Kënga:</strong> <strong>“Dhuratë për ditëlindje”</strong><br>\n<strong>Teksti i këngës:</strong></p>\n<p>Në përvjetor të ditlindjes tënde<br>\nKe plot dhurata mbi tavolinë,<br>\nPo midis tyre një derr i vogël<br>\nFeçkën lëviz dhe hungërrin.<br>\nPo midis tyre një derr i vogël<br>\nLëviz dhe hungërrin</p>\n<p>(Refreni)<br>\nLeht e leht përqark, derri rrotullohet<br>\nVemi anembanë, i trembur po zgjohet<br>\nNjë qesh e sokëllin, një qan e ulërin<br>\nShqipëria jonë kështu është<br>\nNjë qesh e sokëllin një qan e ulërin<br>\nShqipëria jonë kështu është</p>\n<p>Rrugëve me gropa nëpër kanale<br>\nNë parlament zyra partish<br>\nNë katër anët bëhet rrumpallë<br>\nPrish edhe ndreq, ndreq edhe prish<br>\nNë katër anët bëhet rrumpallë<br>\nPrish edhe ndreq dhe prish<br>\nDerr brothers group😃</p>",
      "reply_to_post_number": null,
      "like_count": 0
    },
