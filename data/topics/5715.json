      "cooked": "<p><div class=\"lightbox-wrapper\"><a class=\"lightbox\" href=\"https://peshkupauje.com/uploads/default/original/3X/0/9/0979a99de18b65b9e75d9d1dae18ff65a9b6f96c.jpeg\" data-download-href=\"https://peshkupauje.com/uploads/default/0979a99de18b65b9e75d9d1dae18ff65a9b6f96c\" title=\"5cff6b9e8696d6ab875915a0f500eaa1\"><img src=\"https://peshkupauje.com/uploads/default/optimized/3X/0/9/0979a99de18b65b9e75d9d1dae18ff65a9b6f96c_2_311x400.jpeg\" alt=\"5cff6b9e8696d6ab875915a0f500eaa1\" data-base62-sha1=\"1lOXoQPNCAPdQYNXVsnZNgf6X8g\" width=\"311\" height=\"400\" srcset=\"https://peshkupauje.com/uploads/default/optimized/3X/0/9/0979a99de18b65b9e75d9d1dae18ff65a9b6f96c_2_311x400.jpeg, https://peshkupauje.com/uploads/default/optimized/3X/0/9/0979a99de18b65b9e75d9d1dae18ff65a9b6f96c_2_466x600.jpeg 1.5x, https://peshkupauje.com/uploads/default/optimized/3X/0/9/0979a99de18b65b9e75d9d1dae18ff65a9b6f96c_2_622x800.jpeg 2x\" data-small-upload=\"https://peshkupauje.com/uploads/default/optimized/3X/0/9/0979a99de18b65b9e75d9d1dae18ff65a9b6f96c_2_10x10.png\"><div class=\"meta\">\n<svg class=\"fa d-icon d-icon-far-image svg-icon\" aria-hidden=\"true\"><use href=\"#far-image\"></use></svg><span class=\"filename\">5cff6b9e8696d6ab875915a0f500eaa1</span><span class=\"informations\">654×840 87.3 KB</span><svg class=\"fa d-icon d-icon-discourse-expand svg-icon\" aria-hidden=\"true\"><use href=\"#discourse-expand\"></use></svg>\n</div></a></div></p>",
