      "cooked": "<p>Stalker, amanet Korriksen <img src=\"https://peshkupauje.com/images/emoji/apple/smiley.png?v=12\" title=\":smiley:\" class=\"emoji\" alt=\":smiley:\" loading=\"lazy\" width=\"20\" height=\"20\"></p>",
