      "avatar_template": "/letter_avatar_proxy/v4/letter/p/ecb155/{size}.png",
      "created_at": "2018-12-25T22:15:25.256Z",
      "cooked": "<p>per ty dhe shume te tjere, jam magazinieri, per te tjere jam ai qe ka krijuar, ai protoganisti i disa ngjarjeve historike.</p>",
      "reply_to_post_number": 7,
      "like_count": 0
