      "cooked": "<p><div class=\"lightbox-wrapper\"><a class=\"lightbox\" href=\"https://peshkupauje.com/uploads/default/original/2X/a/a3a902acb908fcf666228471c2b19e8e76d3b93a.jpg\" data-download-href=\"https://peshkupauje.com/uploads/default/a3a902acb908fcf666228471c2b19e8e76d3b93a\" title=\"e54d6305447958e490aee17ba2cff21e--gerhard-picnic.jpg\"><img src=\"https://peshkupauje.com/uploads/default/original/2X/a/a3a902acb908fcf666228471c2b19e8e76d3b93a.jpg\" width=\"611\" height=\"800\" data-small-upload=\"https://peshkupauje.com/uploads/default/optimized/2X/a/a3a902acb908fcf666228471c2b19e8e76d3b93a_2_10x10.png\"><div class=\"meta\">\n<svg class=\"fa d-icon d-icon-far-image svg-icon\" aria-hidden=\"true\"><use xlink:href=\"#far-image\"></use></svg><span class=\"filename\">e54d6305447958e490aee17ba2cff21e--gerhard-picnic.jpg</span><span class=\"informations\">628×822 104 KB</span><svg class=\"fa d-icon d-icon-discourse-expand svg-icon\" aria-hidden=\"true\"><use xlink:href=\"#discourse-expand\"></use></svg>\n</div></a></div></p>",
