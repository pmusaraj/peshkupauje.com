      "avatar_template": "/letter_avatar_proxy/v4/letter/p/ecb155/{size}.png",
      "created_at": "2018-08-11T17:23:50.207Z",
      "cooked": "<p>kjo pune zgjidhet, me nje linje autobuzi te lire, ndermjet Lugines dhe Shqiperise, ku luginasit blejne tekste mesimore ne Shqiperi.</p>",
      "reply_to_post_number": null,
