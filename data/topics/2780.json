      "created_at": "2017-06-13T23:35:16.118Z",
      "cooked": "<p>Mirmbrema<br>\n<img src=\"https://peshkupauje.com/uploads/default/original/2X/b/be204bdfe092bdd74aae38ed221f8a7c0240d484.jpg\" width=\"512\" height=\"195\"></p>",
