      "cooked": "<p><div class=\"lightbox-wrapper\"><a class=\"lightbox\" href=\"https://peshkupauje.com/uploads/default/original/2X/0/04d62cbc61909313111a28b9794b8576888ce71a.jpg\" data-download-href=\"https://peshkupauje.com/uploads/default/04d62cbc61909313111a28b9794b8576888ce71a\" title=\"hockney.jpg\"><img src=\"https://peshkupauje.com/uploads/default/optimized/2X/0/04d62cbc61909313111a28b9794b8576888ce71a_2_200x160.jpg\" alt=\"hockney\" width=\"200\" height=\"160\" srcset=\"https://peshkupauje.com/uploads/default/optimized/2X/0/04d62cbc61909313111a28b9794b8576888ce71a_2_200x160.jpg, https://peshkupauje.com/uploads/default/optimized/2X/0/04d62cbc61909313111a28b9794b8576888ce71a_2_300x240.jpg 1.5x, https://peshkupauje.com/uploads/default/optimized/2X/0/04d62cbc61909313111a28b9794b8576888ce71a_2_400x320.jpg 2x\" data-small-upload=\"https://peshkupauje.com/uploads/default/optimized/2X/0/04d62cbc61909313111a28b9794b8576888ce71a_2_10x10.png\"><div class=\"meta\">\n<svg class=\"fa d-icon d-icon-far-image svg-icon\" aria-hidden=\"true\"><use xlink:href=\"#far-image\"></use></svg><span class=\"filename\">hockney.jpg</span><span class=\"informations\">1098×769 106 KB</span><svg class=\"fa d-icon d-icon-discourse-expand svg-icon\" aria-hidden=\"true\"><use xlink:href=\"#discourse-expand\"></use></svg>\n</div></a></div></p>\n<p>…</p>",
