      "cooked": "<aside class=\"quote no-group\" data-username=\"Kthupi\" data-post=\"11\" data-topic=\"4365\">\n<div class=\"title\">\n<div class=\"quote-controls\"></div>\n<img loading=\"lazy\" alt=\"\" width=\"24\" height=\"24\" src=\"https://peshkupauje.com/letter_avatar_proxy/v4/letter/k/3bc359/48.png\" class=\"avatar\"> Kthupi:</div>\n<blockquote>\n<p>Prandaj iku Swissair?</p>\n</blockquote>\n</aside>\n<p>nga iku, dhe kur iku</p>",
      "reply_to_post_number": 11,
