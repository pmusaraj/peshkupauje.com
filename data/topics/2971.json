      "cooked": "<div class=\"lazyYT\" data-youtube-id=\"z14R8HAAB6I\" data-youtube-title=\"Burning cars at G20 in Hamburg, Germany, 7th July, 2017\" data-width=\"480\" data-height=\"270\" data-parameters=\"feature=oembed&amp;wmode=opaque\"></div>",
