      "avatar_template": "/letter_avatar_proxy/v4/letter/a/ce73a5/{size}.png",
      "created_at": "2017-04-30T22:01:07.753Z",
      "cooked": "<p>Mesiguri e ngateron me gazetarin Gjergj Erebara. Mosha ben te vehten Gjembo, megjithate mbahet mire.</p>",
      "reply_to_post_number": 5,
      "like_count": 0
    },
