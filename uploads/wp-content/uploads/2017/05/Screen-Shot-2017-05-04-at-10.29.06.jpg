  }.liveblog-entry h2,
.liveblog-entry strong {
    font-size: 20px;
    font-weight: 700;
}.liveblog-entry {
    margin-bottom: 25px;
    padding-bottom: 15px;
    border-bottom: 1px solid #eee;
}
/* Rrit madhësinë e titujve brenda Liveblog */
.single-post .liveblog-entry-content strong,
.single-post .liveblog-entry-content b {
    font-size: 22px !important;
    display: block;
    margin-bottom: 6px;
}

/* Nëse përdor H2 brenda entry */
.single-post .liveblog-entry-content h2 {
    font-size: 24px !important;
    margin-bottom: 8px;
}/* Rrit madhësinë e titujve me Bold brenda Liveblog */
.single-post .liveblog-entry-content strong,
.single-post .liveblog-entry-content b,
.single-post .liveblog-entry-text strong,
.single-post .liveblog-entry-text b {
    font-size: 22px !important;
    display: block;
    line-height: 1.3;
    margin-bottom: 8px;
}body.postid-271977 .entry-header h1::before {
    content: "LIVE";
    background: #cc0000;
    color: #fff;
    padding: 4px 8px;
    font-size: 14px;
    font-weight: 700;
    margin-right: 8px;
    border-radius: 3px;
    display: inline-block;
    vertical-align: middle;
}/* Badge LIVE në listime (homepage/kategori/arkiva) për postimet me tag live */
.is-live .post-title a::before{
  content: "LIVE";
  background: #cc0000;
  color: #fff;
  padding: 3px 7px;
  font-size: 12px;
  font-weight: 700;
  margin-right: 6px;
  border-radius: 3px;
  display: inline-block;
  vertical-align: middle;
}
.is-live { outline: 3px solid #cc0000 !important; }

.liveblog-entry-time,
.liveblog-time,
.liveblog-entry-meta time {
    background: #cc0000;
    color: #fff;
    padding: 4px 8px;
    border-radius: 3px;
    font-size: 12px;
    font-weight: 700;
    display: inline-block;
}/* Rregullon meta të Liveblog */
.liveblog-entry-meta {
    display: inline-flex;
    gap: 6px;
    align-items: center;
    background: #f2f2f2;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    color: #111;
    margin-bottom: 8px;
}

/* Heq stilin blu */
.liveblog-entry-meta a,
.liveblog-entry-meta {
    color: #111 !important;
}

/* Mos e lë në dy rreshta */
.liveblog-entry-meta span,
.liveblog-entry-meta time {
    display: inline !important;
}/* Fshih relative time dhe datën */
.liveblog-entry-meta .liveblog-relative-time,
.liveblog-entry-meta .liveblog-date,
.liveblog-entry-meta span:not(time) {
    display: none !important;
}/* Stili vetëm për orën */
.liveblog-entry-meta time {
    background: #111;
    color: #fff;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    display: inline-block;
}/* Kap metan e Liveblog pa ditur klasat ekzakte */
[class*="liveblog"] time,
[class*="liveblog"] .time,
[class*="liveblog"] .entry-date,
[class*="liveblog"] .entry-time {
  outline: 4px solid #00aaff !important;
}/* Fshih relative time (span i parë) */
.liveblog-meta-time span:first-child {
    display: none !important;
}

/* Mbaj vetëm elementin e dytë */
.liveblog-meta-time span:last-child {
    background: #111;
    color: #fff;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    display: inline-block;
}

/* Hiq ngjyrën blu të linkut */
.liveblog-meta-time {
    text-decoration: none !important;
}/* Liveblog: hiq "x minutes ago" (span i parë) */
.liveblog-meta-time span:first-child{
  display:none !important;
}

/* Bëje orën (span i dytë) badge */
.liveblog-meta-time span:last-child{
  background:#111;
  color:#fff;
  padding:4px 8px;
  border-radius:4px;
  font-size:12px;
  font-weight:700;
  display:inline-block;
}

/* hiq underline/blue link */
.liveblog-meta-time{
  text-decoration:none !important;
}/* Fshih datën (span i dytë) */
.liveblog-meta-time span:last-child {
    display: none !important;
}

/* Rregullo pak pamjen e minutes ago */
.liveblog-meta-time span:first-child {
    font-size: 12px;
    font-weight: 600;
}

/* Hiq stilin blu të linkut */
.liveblog-meta-time {
    text-decoration: none !important;
}/* 1) Sigurohu që linku ekziston dhe shfaqet */
.liveblog-meta-time{
  display:inline-block !important;
  text-decoration:none !important;
}

/* 2) Sigurohu që span-at shfaqen (reset) */
.liveblog-meta-time span{
  display:inline !important;
  visibility: visible !important;
  opacity: 1 !important;
}

/* 3) Fsheh vetëm span-in që është datë (p.sh. 01/03/2026) */
.liveblog-meta-time span{
  font-size: 12px;
  font-weight: 600;
}
.liveblog-meta-time span:matches(*){
  /* placeholder – s’bën asgjë, për kompatibilitet */
}

/* CSS pa :matches për shfletuesit: përdorim selector attribute me “/” */
.liveblog-meta-time span[style],
.liveblog-meta-time span:last-child{
  /* mos e përdor këtë, hiqe nëse ke probleme */
}

/* Më e sigurt: fshehim vetëm span-in e dytë POR detyrojmë të parin të duket */
.liveblog-meta-time span:last-child{
  display:none !important;
}
.liveblog-meta-time span:first-child{
  display:inline-block !important;
}

/* 4) (opsionale) bëje minutes-ago si badge */
.liveblog-meta-time span:first-child{
  background:#111;
  color:#fff;
  padding:3px 6px;
  border-radius:3px;
}.liveblog-meta-time span:first-child{
  background:#111;
  color:#fff;
  padding:3px 6px;
  border-radius:3px;
  font-size:12px;
  font-weight:700;
  display:inline-block;
}.live-divider{
  position: relative;
  margin: 28px 0;
  border-top: 4px solid #b30000; /* vija e kuqe */
  height: 0;
}

.live-divider__time{
  position: absolute;
  left: 0;
  top: -20px;              /* ngre kutinë mbi vijë */
  background: #b30000;     /* kutia e kuqe */
  color: #fff;
  font-weight: 700;
  padding: 6px 14px;
  line-height: 1;
  border-radius: 2px;
  font-size: 16px;
}.bota-label{
  display: inline-block;
  background: #000;
  color: #fff;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 6px 10px;
  margin-bottom: 12px;
}.bota-label{
  display:inline-block;
  color:#fff;
  font-weight:700;
  font-size:11px;
  letter-spacing:1.5px;
  text-transform:uppercase;
  padding:6px 12px;
  margin-bottom:14px;
}

/* Ngjyrat */

.bota-label-black{
  background:#000;
}

.bota-label-red{
  background:#b30000;
}

.bota-label-blue{
  background:#003366;
}

.bota-label-gray{
  background:#444;
}		</style>
