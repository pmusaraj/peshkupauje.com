<script type="text/javascript">
@media (max-width: 767px){

  /* Butoni ynë premium */
  .bota-native-share-btn{
    width:44px;
    height:44px;
    border:0;
    border-radius:10px;
    background:#111;
    color:#fff;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:0;
    margin:0;
    cursor:pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .bota-native-share-btn:active{ transform: translateY(1px); }

  .bota-native-share-btn svg{
    width:20px;
    height:20px;
    display:block;
  }

  .bota-native-share-btn.copied{
    opacity:.92;
  }

  /* Mos lejo që të duket si tekst link */
  .bota-native-share-wrap{
    display:inline-flex;
    align-items:center;
    gap:8px;
  }

  /* Siguro rresht të rregullt për ikonat e share */
  .tie-share-buttons, .tie-social-share, .post-share, .single-share, .share-buttons,
  .entry-share, .social-share, .post-bottom-share{
    display:flex;
    flex-wrap:wrap;
    align-items:center;
    gap:8px;
  }

  /* nëse tema ka share bar fixed poshtë, mos e prek */
}

@media (min-width: 768px){
  .bota-native-share-btn, .bota-native-share-wrap{ display:none !important; }
}</script>
