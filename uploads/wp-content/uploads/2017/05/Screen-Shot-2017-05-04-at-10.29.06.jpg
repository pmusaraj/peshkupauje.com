<!-- bota.al – iPhone Safari “Add to Home Screen” banner (paste in WPCode → Footer) -->
<style>
  #botaA2HSBanner{position:fixed;left:0;right:0;bottom:0;z-index:999999;background:#0b1220;color:#fff;
    padding:12px 14px;box-shadow:0 -6px 18px rgba(0,0,0,.25);font:14px/1.3 system-ui,-apple-system,Segoe UI,Roboto,Arial}
  #botaA2HSBanner .row{display:flex;gap:10px;align-items:flex-start;max-width:1100px;margin:0 auto}
  #botaA2HSBanner .icon{width:34px;height:34px;border-radius:9px;background:#1f2a44;display:flex;align-items:center;justify-content:center;flex:0 0 34px}
  #botaA2HSBanner .txt{flex:1}
  #botaA2HSBanner .title{font-weight:700;margin:0 0 2px}
  #botaA2HSBanner .desc{margin:0;opacity:.9}
  #botaA2HSBanner .actions{display:flex;gap:8px;align-items:center;flex:0 0 auto}
  #botaA2HSBanner button{border:0;border-radius:10px;padding:9px 10px;cursor:pointer;font-weight:600}
  #botaA2HSBanner .how{background:#ffffff;color:#0b1220}
  #botaA2HSBanner .close{background:transparent;color:#fff;opacity:.8;font-size:18px;line-height:1;padding:6px 10px}
  #botaA2HSModalBackdrop{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:1000000;display:none}
  #botaA2HSModal{position:fixed;left:50%;top:50%;transform:translate(-50%,-50%);width:min(520px,92vw);
    background:#fff;color:#0b1220;border-radius:14px;padding:16px 16px 12px;z-index:1000001;display:none}
  #botaA2HSModal h3{margin:0 0 8px;font:700 16px/1.2 system-ui,-apple-system,Segoe UI,Roboto,Arial}
  #botaA2HSModal .lead{margin:0 0 10px;font-size:14px}
  #botaA2HSModal .hint{font-size:13px;opacity:.85;margin:0 0 10px}
  #botaA2HSModal ol{margin:0 0 12px;padding-left:18px}
  #botaA2HSModal li{margin:6px 0}
  #botaA2HSModal .modalClose{width:100%;background:#0b1220;color:#fff;border-radius:12px;padding:10px 12px;font-weight:700;border:0;cursor:pointer}
</style>

<div id="botaA2HSBanner" role="region" aria-label="Njoftime iPhone" style="display:none">
  <div class="row">
    <div class="icon">🔔</div>
    <div class="txt">
      <p class="title">Merr njoftime nga bota.al në iPhone</p>
      <p class="desc">Shto faqen në Home Screen: <b>Share ⬆️</b> → <b>Add to Home Screen</b>.</p>
    </div>
    <div class="actions">
      <button class="how" type="button" id="botaA2HSHow">Si ta bëj?</button>
      <button class="close" type="button" aria-label="Mbyll" id="botaA2HSClose">×</button>
    </div>
  </div>
</div>

<div id="botaA2HSModalBackdrop"></div>
<div id="botaA2HSModal" role="dialog" aria-modal="true" aria-label="Si të aktivizosh njoftimet në iPhone">
  <h3>Si të marrësh njoftime në iPhone (Safari)</h3>
  <p class="lead"><b>Merr lajmet më të rëndësishme direkt në telefonin tënd.</b></p>
  <p class="hint">Apple i lejon njoftimet vetëm kur faqja është shtuar si ikonë në Home Screen.</p>
  <ol>
    <li>Hap <b>bota.al</b> në <b>Safari</b>.</li>
    <li>Shtyp butonin <b>Share ⬆️</b> (katror me shigjetë lart).</li>
    <li>Zgjidh <b>Add to Home Screen</b>.</li>
    <li>Hape bota.al nga ikona në Home Screen.</li>
    <li>Kur të dalë kërkesa, shtyp <b>Allow</b>.</li>
  </ol>
  <button class="modalClose" type="button" id="botaA2HSModalClose">OK</button>
</div>

<script>
(function(){
  // --- Detection: iOS Safari (not Chrome/Firefox), not already installed (standalone) ---
  const ua = navigator.userAgent || "";
  const isIOS = /iPhone|iPad|iPod/i.test(ua) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
  const isSafari = isIOS && /Safari/i.test(ua) && !/CriOS|FxiOS|EdgiOS|OPiOS/i.test(ua);
  const isStandalone = (window.navigator.standalone === true) || (window.matchMedia && window.matchMedia('(display-mode: standalone)').matches);

  // --- Frequency cap (hide for 7 days after closing) ---
  const KEY = "bota_a2hs_hide_until";
  const now = Date.now();
  const hideUntil = parseInt(localStorage.getItem(KEY) || "0", 10);

  if(!isSafari || isStandalone || now < hideUntil) return;

  const banner = document.getElementById("botaA2HSBanner");
  const closeBtn = document.getElementById("botaA2HSClose");
  const howBtn = document.getElementById("botaA2HSHow");
  const modal = document.getElementById("botaA2HSModal");
  const backdrop = document.getElementById("botaA2HSModalBackdrop");
  const modalClose = document.getElementById("botaA2HSModalClose");

  function showBanner(){ banner.style.display = "block"; }
  function hideBanner(days){
    const ms = (days||7) * 24 * 60 * 60 * 1000;
    localStorage.setItem(KEY, String(Date.now() + ms));
    banner.style.display = "none";
  }
  function openModal(){
    backdrop.style.display = "block";
    modal.style.display = "block";
  }
  function closeModal(){
    modal.style.display = "none";
    backdrop.style.display = "none";
  }

  closeBtn.addEventListener("click", ()=>hideBanner(7));
  howBtn.addEventListener("click", openModal);
  backdrop.addEventListener("click", closeModal);
  modalClose.addEventListener("click", closeModal);

  // --- Smarter trigger: wait 12s AND user scrolls at least 35% ---
  let timeOk = false;
  let shown = false;

  function scrollPercent(){
    const doc = document.documentElement;
    const scrollTop = window.pageYOffset || doc.scrollTop || 0;
    const height = (doc.scrollHeight || 0) - (doc.clientHeight || 0);
    if(height <= 0) return 100;
    return (scrollTop / height) * 100;
  }

  function maybeShow(){
    if(shown) return;
    if(!timeOk) return;
    if(scrollPercent() < 35) return;
    shown = true;
    showBanner();
    window.removeEventListener('scroll', maybeShow, {passive:true});
  }

  setTimeout(()=>{ timeOk = true; maybeShow(); }, 12000);
  window.addEventListener('scroll', maybeShow, {passive:true});
})();
</script><div id="autocomplete-suggestions" class="autocomplete-suggestions"></div><div id="is-scroller-outer"><div id="is-scroller"></div></div><div id="fb-root"></div>		<div id="tie-popup-search-desktop" class="tie-popup tie-popup-search-wrap" style="display: none;">
