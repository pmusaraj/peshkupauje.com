			.lexo-edhe-box{
  border-top:2px solid #111;
  margin:28px 0;
  padding-top:14px;
}

.lexo-edhe-title{
  font-weight:700;
  letter-spacing:.06em;
  text-transform:uppercase;
  font-size:13px;
  margin-bottom:12px;
}

.lexo-edhe-list{
  display:flex;
  flex-direction:column;
}

.lexo-edhe-row{
  display:flex;
  gap:14px;
  padding:12px 0;
  text-decoration:none !important;
  color:inherit;
  border-top:1px solid rgba(0,0,0,.10);
}

.lexo-edhe-row:first-child{
  border-top:0;
  padding-top:0;
}

.lexo-edhe-thumb img,
.lexo-edhe-thumb-fallback{
  width:120px;
  height:82px;
  object-fit:cover;
  border-radius:4px;
  background:rgba(0,0,0,.08);
  display:block;
}

.lexo-edhe-meta{
  flex:1;
  min-width:0;
}

.lexo-edhe-cat{
  font-size:12px;
  opacity:.7;
  text-transform:uppercase;
  margin-bottom:2px;
}

.lexo-edhe-h{
  font-size:16px;
  line-height:1.2;
  font-weight:700;
  margin-bottom:4px;
}

.lexo-edhe-ex{
  font-size:13px;
  line-height:1.45;
  opacity:.85;
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;
}

.lexo-edhe-row:hover .lexo-edhe-h{
  text-decoration:underline;
}

/* Mobile */
